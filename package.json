{
  "name": "super-agentes-b2c-v1",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "install:all": "cd server && npm install && cd ../web && npm install --legacy-peer-deps",
    "build:server": "cd server && npx tsc",
    "build:web": "cd web && npx vite build --outDir ../web-dist",
    "build": "npm run build:server && npm run build:web",
    "start": "node server/dist/index.js",
    "dev:server": "cd server && npx tsx src/index.ts",
    "dev:web": "cd web && npx vite",
    "postinstall": "npm run install:all"
  }
}
